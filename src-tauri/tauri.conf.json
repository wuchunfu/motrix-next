{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "motrix-next",
  "version": "0.1.0",
  "identifier": "com.motrix.next",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Motrix Next",
        "width": 1024,
        "height": 768,
        "minWidth": 800,
        "minHeight": 540,
        "transparent": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/aria2c"
    ],
    "resources": [
      "binaries/aria2.conf"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/AnInsomniacy/motrix-next/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  }
}